{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://paperincbackend.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://paperincbackend.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
